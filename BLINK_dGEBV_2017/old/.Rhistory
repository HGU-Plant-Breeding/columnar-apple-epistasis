"clean_in_len_2018_pop.csv",
"clean_lsh_ang_1_2017_pop.csv",
"clean_lsh_ang_1_2018_pop.csv",
"clean_tr_brz_1_2017_pop.csv",
"clean_tr_brz_1_2018_pop.csv",
"clean_tr_brz_2_2017_pop.csv",
"clean_tr_brz_2_2018_pop.csv",
"clean_tr_brz_prop_2017_pop.csv",
"clean_tr_brz_prop_2018_pop.csv",
"clean_tr_coni_2017_pop.csv",
"clean_tr_coni_2018_pop.csv",
"clean_tr_dia_1_2017_pop.csv",
"clean_tr_dia_1_2018_pop.csv",
"clean_tr_dia_2_2017_pop.csv",
"clean_tr_dia_2_2018_pop.csv",
"clean_tr_len_2017_pop.csv",
"clean_tr_len_2018_pop.csv"
)
BASE <- "C:/Users/nguevenc/Desktop/R_Working_Directory/Lidar/Single_trait_walkthrough/outlier_removed_raw"
files <- file.path(BASE, files)
# ── 2) Helper to extract trait column automatically ───────────────────────────
get_value_col <- function(dt) {
num_cols <- names(dt)[sapply(dt, is.numeric)]
# Pick numeric column that is not Year, Row, Column, rep, co_loc_PCR
ignore <- c("Year", "Row", "Column", "rep", "co_loc_PCR")
num_cols <- setdiff(num_cols, ignore)
num_cols[1]  # first numeric trait column
}
# ── 3) Read + compute CV per genotype × year ──────────────────────────────────
cv_tab <- rbindlist(lapply(files, function(f) {
dt <- fread(f)
val_col <- get_value_col(dt)
# Compute mean, SD, CV per genotype
dt_summary <- dt %>%
group_by(Genotype, Year) %>%
summarise(
Mean = mean(.data[[val_col]], na.rm = TRUE),
SD   = sd(.data[[val_col]], na.rm = TRUE),
CV   = 100 * SD / Mean,
.groups = "drop"
)
# Add trait name
dt_summary <- dt_summary %>%
mutate(Trait = gsub("clean_|_pop.csv", "", basename(f)))
data.table(dt_summary)
}), fill = TRUE)
# Optional: if you want **overall CV per trait × year**, aggregate over genotypes
cv_overall <- cv_tab %>%
group_by(Trait, Year) %>%
summarise(
Mean = mean(Mean, na.rm = TRUE),
SD   = mean(SD, na.rm = TRUE),
CV   = mean(CV, na.rm = TRUE),
.groups = "drop"
)
cv_overall <- cv_overall %>%
mutate(Trait = gsub("_2017|_2018", "", Trait))
# ── 4) Save table ─────────────────────────────────────────────────────────────
fwrite(cv_overall, file = "Suppl_Table_CV_raw_traits_genotypewise.csv")
# ── 5) Plot ─────────────────────────────────────────────────────────────────
p <- ggplot(cv_overall, aes(x = Trait, y = CV, fill = factor(Year))) +
geom_col(position = position_dodge(width = 0.8), width = 0.7) +
labs(y = "Coefficient of variation (%)", x = NULL, fill = "Year") +
theme_bw(base_size = 11) +
theme(axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "top")
ggsave("Suppl_Fig_CV_raw_traits_genotypewise.png", p, width = 9, height = 4.5, dpi = 300)
cv_overall
p
ggsave("Suppl_Fig_CV_raw_traits_genotypewise.svg", p, width = 9, height = 4.5, dpi = 300)
getwd
getwd()
rm(list = ls(all = TRUE)); graphics.off()
