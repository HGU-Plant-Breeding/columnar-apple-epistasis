# ──────────────────────────────────────────────────────────────────────────────
# 1) Libraries (minimal)
suppressPackageStartupMessages({
library(ASRgenomics)
library(AGHmatrix)
library(asreml)
vm <- get("asr_vm", envir = asNamespace("asreml"))
library(dplyr)
