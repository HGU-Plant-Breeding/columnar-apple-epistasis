#              avg_R, avg_G, avg_B, circularity, CIE_a
# в”Ђв”Ђ Load: OutRmv if it exists, otherwise FULL в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
full_file   <- file.path(FQ_DIR, if (DATASET == "JA") "juice_antho_traits_FULL.csv"
else                  "firmness_rgb_FULL.csv")
outrmv_file <- sub("_FULL", "_OutRmv", full_file)
in_file     <- if (file.exists(outrmv_file)) outrmv_file else full_file
cat(sprintf("Loading: %s\n", basename(in_file)))
df_full <- read.csv(in_file, sep = ";") %>%
mutate(
