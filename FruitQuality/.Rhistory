cat(sprintf("Rows: %d | Non-NA %s: %d\n", nrow(df_full), TRAIT,
sum(!is.na(df_full[[TRAIT]]))))
# в”Ђв”Ђ GRM в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
Ginv <- readRDS(file.path(SNP_DIR, "MASTER_Ginv_flt_imp", "Ginv_FQ.rds"))
missing_from_ginv <- setdiff(levels(df_full$Genotype), attr(Ginv, "rowNames"))
df_full <- df_full %>%
mutate(Genotype = if_else(Genotype %in% missing_from_ginv,
factor(NA, levels = levels(Genotype)),
Genotype))
# в”Ђв”Ђ anthocyanin restriction в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if (TRAIT == "anthocyanin") {
df_full$pop    <- factor(df_full$pop, levels = c("bibon", "pxw"))
df_full        <- df_full[df_full$location != "fuchsberg", ]
df_full$loc_yr <- droplevels(df_full$loc_yr)
}
# в”Ђв”Ђ df_fit: drop bibon for JA to avoid spatial singularities в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Bibon has only 7/13 obs per year вЂ” too sparse for at(loc_yr):row + at(loc_yr):column.
# Outliers are detected on df_fit (non-bibon), then propagated back to df_full.
# Bibon observations are left as-is in df_full (not outlier-checked via this model).
if (DATASET == "JA") {
df_fit        <- df_full[df_full$location != "bibon", ]
df_fit$loc_yr <- droplevels(df_fit$loc_yr)
df_fit$pop    <- droplevels(df_fit$pop)
cat(sprintf("Fitting on non-bibon data: %d non-NA %s obs\n",
sum(!is.na(df_fit[[TRAIT]])), TRAIT))
} else {
df_fit <- df_full
}
# в”Ђв”Ђ Sort в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if (DATASET == "JA") {
df_fit <- df_fit[order(df_fit$loc_yr, df_fit$row, df_fit$column), ]
} else {
df_fit <- df_fit[order(df_fit$location, df_fit$year,
df_fit$row, df_fit$column, df_fit$rep), ]
}
# в”Ђв”Ђ Fixed formula в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
fixed_frm <- as.formula(paste(TRAIT, "~ pop + rootstock"))
# в”Ђв”Ђ Fit model в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if (DATASET == "JA") {
m_fit <- asreml(
fixed     = fixed_frm,
random    = ~ corh(loc_yr):vm(Genotype, Ginv)
+ at(loc_yr):row + at(loc_yr):column,
residual  = ~ dsum(~ ar1(row):ar1(column) | loc_yr),
data      = df_fit,
na.action = na.method(y = "include", x = "include"),
ai.sing   = FALSE, maxit = 30, workspace = "2gb"
)
} else {
m_fit <- asreml(
fixed     = fixed_frm,
random    = ~ corh(loc_yr):vm(Genotype, Ginv)
+ at(loc_yr):row + at(loc_yr):column,
residual  = ~ dsum(~ idv(units) | loc_yr),
data      = df_fit,
na.action = na.method(y = "include", x = "include"),
ai.sing   = FALSE, maxit = 30, workspace = "2gb"
)
}
while (!m_fit$converge) m_fit <- update(m_fit)
m_fit <- update(m_fit, aom = TRUE)
# в”Ђв”Ђ Outlier detection and removal (repeat until n_out = 0) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
repeat {
z     <- m_fit$aom$R[, "stdCondRes"]
f     <- as.numeric(fitted(m_fit))
n_out <- sum(abs(z) > 3, na.rm = TRUE)
print(
df_fit %>%
mutate(fitted = f, z = z,
flag = ifelse(!is.na(z) & abs(z) > 3, "Outlier (|z|>3)", "Inlier")) %>%
filter(!is.na(z)) %>%
ggplot(aes(fitted, z, colour = flag)) +
geom_hline(yintercept = c(-3, 3), linetype = 2,
linewidth = 0.5, colour = "grey40") +
geom_point(size = 1.6, alpha = 0.9) +
facet_wrap(~ loc_yr, scales = "free_x", ncol = 3) +
scale_colour_manual(
values = c("Outlier (|z|>3)" = "#d73027", "Inlier" = "#333333")) +
labs(title  = paste0("Standardised conditional residuals вЂ” ",
TRAIT, " (", DATASET, ")"),
x = "Fitted values", y = "stdCondRes", colour = "") +
theme_bw(base_size = 12) +
theme(plot.title = element_text(face = "bold", hjust = 0.5))
)
cat(sprintf("Outliers |stdCondRes| > 3: %d\n", n_out))
if (n_out == 0) break
df_fit[[TRAIT]][abs(z) > 3] <- NA_real_
while (!m_fit$converge) m_fit <- update(m_fit)
m_fit <- update(m_fit, aom = TRUE)
}
# в”Ђв”Ђ Propagate blanked values back into df_full в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Bibon rows in df_full are untouched вЂ” they were not part of the model
if (DATASET == "JA") {
key_fit  <- paste(df_fit$location,  df_fit$row,  df_fit$column,  sep = "_")
key_full <- paste(df_full$location, df_full$row, df_full$column, sep = "_")
} else {
key_fit  <- paste(df_fit$location,  df_fit$row,  df_fit$column,
df_fit$rep,  sep = "_")
key_full <- paste(df_full$location, df_full$row, df_full$column,
df_full$rep, sep = "_")
}
df_full[[TRAIT]][match(key_fit, key_full)] <- df_fit[[TRAIT]]
cat(sprintf("\nFinal non-NA %s in full df (incl. bibon): %d\n",
TRAIT, sum(!is.na(df_full[[TRAIT]]))))
# в”Ђв”Ђ Save в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
write.table(df_full, outrmv_file, sep = ";", row.names = FALSE, quote = FALSE)
cat(sprintf("Saved: %s\n", outrmv_file))
rm(list = ls(all = TRUE)); graphics.off(); closeAllConnections()
suppressPackageStartupMessages({
library(asreml)
vm <- get("asr_vm", envir = asNamespace("asreml"))
library(dplyr)
library(ggplot2)
})
