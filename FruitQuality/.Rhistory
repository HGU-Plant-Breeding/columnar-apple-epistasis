if (DATASET == "JA") {
key_fit  <- paste(df_fit$location,  df_fit$row,  df_fit$column,  sep = "_")
key_full <- paste(df_full$location, df_full$row, df_full$column, sep = "_")
} else {
key_fit  <- paste(df_fit$location,  df_fit$row,  df_fit$column,
df_fit$rep,  sep = "_")
key_full <- paste(df_full$location, df_full$row, df_full$column,
df_full$rep, sep = "_")
}
df_full[[TRAIT]][match(key_fit, key_full)] <- df_fit[[TRAIT]]
cat(sprintf("\nFinal non-NA %s in full df (incl. bibon): %d\n",
TRAIT, sum(!is.na(df_full[[TRAIT]]))))
# в”Ђв”Ђ Save в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
write.table(df_full, outrmv_file, sep = ";", row.names = FALSE, quote = FALSE)
cat(sprintf("Saved: %s\n", outrmv_file))
