j <- read.csv("C:/Users/nguevenc/Desktop/R_Working_Directory/MLM/HBLUP/Deregression/july_PRM_drg.csv", sep = ",")
dry <- read.csv("C:/Users/nguevenc/Desktop/R_Working_Directory/MLM/HBLUP/Deregression/dry_PRM_drg.csv", sep = ",")
j_s <- read.csv("C:/Users/nguevenc/Desktop/R_Working_Directory/MLM/HBLUP/Deregression/j_s_PRM_drg.csv", sep = ",")
H <- j
rownames(H) <- H[,1]
H <- H[,-c(1)]
H <- as.matrix(H)
diag(H) <- diag(H) + 1e-6
Hinv_list <- G.inverse(H, sparseform = FALSE)
Hinv_j      <- Hinv_list$Ginv
#===============================================================================
# STEP 6.5.1 : HBLUP July
#===============================================================================
GTs_j <- unique(rownames(Hinv_j)); df_full_j <- df_full[df_full$Genotype %in% GTs_j,]
hblup_j <- asreml(firmness ~ 1,
random   = ~ vm(Genotype, Hinv_j) + at(Location):Row + at(Location):Column+ rep,
residual = ~ units,
data     = df_full_j,
na.action = na.method(y = "include", x = "include"))
# plot(hblup_j)
summary(hblup_j)$varcomp ## check the z ratios for the importance of Column, Row and residual variance structure
hblup_j.sum <- summary.asreml(hblup_j)
logl_hblup_dry <- summary(hblup_j)$loglik
aic_hblup_dry <- summary(hblup_j)$aic; aic_hblup_dry
#===============================================================================
# STEP 7.1 : AIC comparison
#===============================================================================
aic_hblup_j; aic_hblup_dry
# plot(hblup_dry)
summary(hblup_dry)$varcomp ## check the z ratios for the importance of Column, Row and residual variance structure
hblup_dry.sum <- summary.asreml(hblup_dry)
logl_hblup_dry <- summary(hblup_dry)$loglik
aic_hblup_dry <- summary(hblup_dry)$aic; aic_hblup_dry
# plot(hblup_j)
summary(hblup_j)$varcomp ## check the z ratios for the importance of Column, Row and residual variance structure
hblup_j.sum <- summary.asreml(hblup_j)
logl_hblup_j <- summary(hblup_j)$loglik
aic_hblup_j <- summary(hblup_j)$aic; aic_hblup_dry
aic_hblup_j <- summary(hblup_j)$aic; aic_hblup_j
