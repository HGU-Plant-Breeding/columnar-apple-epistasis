#===============================================================================
# STEP 6.0 : Basemodel m0
#===============================================================================
firmness.m0 <- asreml(firmness ~ 1, #Fixed effects
random= ~Genotype, #Random
residual = ~units, #Residuals - lowest level unit
data= df_full, na.action = na.method(x = "include")) #inlcude data with NAs in x variables (as well as observed)
summary(firmness.m0)$varcomp #Variance components very important - Z score to test significance Typically, if𝑍>1.96 random effect statistically significant at p 0.05.
plot(firmness.m0)
#save model statistics
logl_m0 <- summary(firmness.m0)$loglik
logl_aic_m0 <- summary(firmness.m0)$aic
#Test for outliers using scaled residuals - be very careful here if you have no replicates - only remove outliers that are crazy obvious... do outlier detection properly with GRM..
temp.fm <- firmness.m0
out <- update(temp.fm,aom=T)
outlier.df <- df_full
outlier.df$scres <- out$aom$R[,2]
outliers <- outlier.df[!is.na(outlier.df$scres)& abs(outlier.df$scres)>5, ] ###Here is where you set the outlier threshold - set to 5 due to no reps
outliers <- outliers[, c('Genotype','scres','firmness')]
outliers <- outliers[!is.na(outliers$scres), ]
print(outliers)
#Only to be used if you want to remove outliers - need to enter in the specific year, column and row details for the plot
df_full$firmness[df_full$Genotype %in% outliers$Genotype & df_full$firmness %in% outliers$firmness] <- NA
