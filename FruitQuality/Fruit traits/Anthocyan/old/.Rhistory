library(snpReady)
library(impute)
# Define population colors
pop_colors <- c(
bibon = "#1f78b4",  # blue
gxr   = "#33a02c",  # green
pxa   = "#e31a1c",  # red
pxw   = "#ff7f00"   # orange
)
c130_matrix <- read.csv("C:/Users/nguevenc/Desktop/R_Working_Directory/SNP Chip/GT_filtered_numeric_transposed.csv", sep = ",")
n <- nrow(c130_matrix)
rownames(c130_matrix) <- c130_matrix$X
c130_matrix <- c130_matrix[, -(1)]
colnames(c130_matrix) <- gsub("^AX\\.", "AX-", colnames(c130_matrix))
c130_matrix <- as.matrix(c130_matrix)
c130_df <- as.data.frame(c130_matrix)
#===============================================================================
# STEP 2: MAF Filter Subpopulation
#===============================================================================
#### Anthocyanin
setwd("C:/Users/nguevenc/Desktop/R_Working_Directory/Fruit traits/Anthocyan")
df_full <- read.csv("df_full_antho.csv", sep = ",")
df_full$Genotype <- as.factor(df_full$Genotype)
df_full <- df_full[,-c(1)]
df_full <- df_full %>% mutate(across(c(1:4, 6:7), as.factor))
# df_full <- df_full[df_full$Genotype %in% rownames(c130_df),]   ### dont run, we already load an expanded grid
# df_full <- df_full[!duplicated(df_full$Genotype),]
# the GTs in MYB subpopulations PxW and Bibon
keep <- sort(intersect(rownames(c130_df), df_full$Genotype))
# subset the matrix to only those
c130_matrix <- c130_matrix[keep, ]
# MAF filter by subpopulation
geno_sub <- c130_matrix
maf_sub  <- colMeans(geno_sub, na.rm=TRUE) / 2
keep     <- names(maf_sub)[maf_sub >= 0.05 & maf_sub <= 0.95]
c130_matrix_filtered <- c130_matrix[, keep] # Keep only the columns (SNPs) whose names are in the 'keep' vector
message("After sub‐pop MAF filtering: ", length(keep), " SNPs retained")
c130_df <- as.data.frame(c130_matrix_filtered)
#===============================================================================
# STEP 3: BUILD DOMINANCE MATRIX (D) VIA VITEZICA ET AL. (ASRgenomics)
#===============================================================================
drm_results <- ASRgenomics::G.matrix(
M      = c130_matrix_filtered,
method = "Vitezica"
)
DRM <- drm_results$G
diag(DRM) <- diag(DRM) + 0.01
Dinv <- G.inverse(DRM, sparseform = FALSE)$Ginv
#===============================================================================
# STEP 4: IMPUTE & BUILD ADDITIVE GRM (GRM) VIA VanRaden (snpReady)
#===============================================================================
c130_matrix_imputed <- c130_matrix_filtered
if (any(is.na(c130_matrix_imputed))) {
message("Missing values found. Performing mean imputation.")
col_means <- colMeans(c130_matrix_imputed, na.rm = TRUE)
for (j in 1:ncol(c130_matrix_imputed)) {
c130_matrix_imputed[is.na(c130_matrix_imputed[, j]), j] <- col_means[j]
}
} else {
message("No missing values found.")
}
grm_results <- G.matrix(
M      = c130_matrix_imputed,
method = "VanRaden",
format = "wide"
)
str(grm_results)
GRM <- grm_results$Ga
diag(GRM) <- diag(GRM) + 0.01
Ginv <- G.inverse(GRM, sparseform = FALSE)$Ginv
#===============================================================================
# STEP 5: Add GWAS SNPs and calculate G and D without them
#===============================================================================
GWAS_SNPs <- c("AX-115343781", "AX-115333927", "AX-115308966","AX-115442369", "AX-635441221", "AX-115186872", "AX-115356965")
# (a) Make your SNP_matrix from the *imputed* data
SNP_matrix <- c130_matrix_imputed[, GWAS_SNPs, drop=FALSE]
message("Created SNP_matrix with ", ncol(SNP_matrix), " GWAS SNPs.")
# (b) Now take your *unimputed* filtered matrix, drop exactly those same SNPs …
keep_cols            <- setdiff(colnames(c130_matrix_filtered),
colnames(SNP_matrix))
c130_matrix_noMYB <- c130_matrix_filtered[ , keep_cols]
#===============================================================================
# BUILD DOMINANCE MATRIX (D) VIA VITEZICA ET AL. (ASRgenomics)
drm_results <- ASRgenomics::G.matrix(
M      = c130_matrix_noMYB,
method = "Vitezica"
)
DRM <- drm_results$G
diag(DRM) <- diag(DRM) + 0.01
Dinv_noMYB <- G.inverse(DRM, sparseform = FALSE)$Ginv
#===============================================================================
# IMPUTE & BUILD ADDITIVE GRM (GRM) VIA VanRaden (snpReady)
if (any(is.na(c130_matrix_noMYB))) {
message("Missing values found. Performing mean imputation.")
col_means <- colMeans(c130_matrix_noMYB, na.rm = TRUE)
for (j in 1:ncol(c130_matrix_noMYB)) {
c130_matrix_noMYB[is.na(c130_matrix_noMYB[, j]), j] <- col_means[j]
}
} else {
message("No missing values found.")
}
grm_results <- G.matrix(
M      = c130_matrix_noMYB,
method = "VanRaden",
format = "wide"
)
str(grm_results)
GRM <- grm_results$Ga
diag(GRM) <- diag(GRM) + 0.01
Ginv_noMYB <- G.inverse(GRM, sparseform = FALSE)$Ginv
#===============================================================================
# add removed marker(s) to df_full to later use as fixed effect
SNP_df <- as.data.frame(SNP_matrix)
SNP_df$Genotype <- rownames(SNP_df)
df_full <- df_full %>%
left_join(
SNP_df,
by = "Genotype"
)
colnames(df_full) <- gsub("^AX\\-", "AX.", colnames(df_full))
df_full$Genotype <- as.factor(df_full$Genotype)
#===============================================================================
# STEP 6 : Modelling
#===============================================================================
#===============================================================================
# STEP 6.0 : BASE GRM   (no reps so base model wouldnt run)
#===============================================================================
asreml.options(workspace="20gb")
base.grm <- asreml(Anthocyans.ug.mg ~ 1,
random   = ~ vm(Genotype, Ginv) + at(Location):Row + at(Location):Column,
residual = ~ units,
data     = df_full,
na.action = na.method(y = "include", x = "include"))
base.grm<- update.asreml(base.grm, maxit= 30)
# plot(base.grm)
summary(base.grm)$varcomp ## check the z ratios for the importance of Column, Row and residual variance structure
base.grm.sum <- summary.asreml(base.grm)
logl_base.grm <- summary(base.grm)$loglik
aic_base.grm <- summary(base.grm)$aic
logl_base.grm
aic_base.grm_with_outliers <- aic_base.grm ; aic_base.grm
#===============================================================================
# STEP 6.1 : Outlier Detection with BASE GRM   --- RUN TWICE
#===============================================================================
temp.fm <- base.grm
out <- update(temp.fm,aom=T)
outlier.df <- df_full
outlier.df$scres <- out$aom$R[,2]
outliers <- outlier.df[!is.na(outlier.df$scres)& abs(outlier.df$scres)>4, ]     ### outlier threshold - set to 4
outliers <- outliers[, c('Genotype','scres','Anthocyans.ug.mg')]
outliers <- outliers[!is.na(outliers$scres), ]
print(outliers)
df_full$Anthocyans.ug.mg[df_full$Genotype %in% outliers$Genotype & df_full$Anthocyans.ug.mg %in% outliers$Anthocyans.ug.mg] <- NA
base.grm <- asreml(Anthocyans.ug.mg ~ 1,
random   = ~ vm(Genotype, Ginv) + at(Location):Row + at(Location):Column,
residual = ~ units,
data     = df_full,
na.action = na.method(y = "include", x = "include"))
base.grm<- update.asreml(base.grm, maxit= 30)
# plot(base.grm)
summary(base.grm)$varcomp ## check the z ratios for the importance of Column, Row and residual variance structure
base.grm.sum <- summary.asreml(base.grm)
logl_base.grm <- summary(base.grm)$loglik
aic_base.grm <- summary(base.grm)$aic
logl_base.grm
aic_base.grm; aic_base.grm_with_outliers
