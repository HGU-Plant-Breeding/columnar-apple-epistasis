aic_base.grm_with_outliers; aic_base.grm; aic_MYB_model; aic_MYB_model_dom
aic_df <- data.frame(
model = c("base.grm_with_outliers", "base.grm", "MYB_model", "MYB_model_dom"),
AIC   = c(122.3359, 65.39271 ,  29.96464 ,      31.96463))
# (2) Convert 'model' into a factor so the x‐axis respects this order:
aic_df$model <- factor(aic_df$model,
levels = c("base.grm_with_outliers", "base.grm", "MYB_model", "MYB_model_dom"))
# (3) Now plot a line + points, with the AIC number printed above each point:
ggplot(aic_df, aes(x = model, y = AIC, group = 1)) +
geom_line(color = "#1f78b4", size = 1) +
geom_point(color = "#1f78b4", size = 3) +
geom_text(aes(label = round(AIC, 2)),
vjust = -0.6, size = 4) +
scale_y_continuous(expand = expansion(mult = c(0.02, 0.10))) +
theme_minimal(base_size = 14) +
theme(
plot.title     = element_text(hjust = 0.5, size = 16, face = "bold"),
axis.text.x    = element_text(angle = 25, hjust = 1, size = 12),
axis.title.x   = element_blank(),
axis.title.y   = element_text(size = 14),
panel.grid.minor = element_blank()
) +
labs(
title = "Comparison of Model AICs",
y     = "AIC"
)
