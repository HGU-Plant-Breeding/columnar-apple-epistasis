# extract the fixed‐effect estimates
fe <- as.data.frame(coef(MYB_model_dom)$fixed)
fe
b1 <- fe[2,]
b2 <- fe[3,]
# 1) get your random‐effect BLUPs
blups <- predict.asreml(MYB_model_dom, classify = "Genotype", aliased  = TRUE)$pvals %>% select(Genotype, u = predicted.value)
# 2) grab each genotype’s SNP dosages
snp_dosage <- df_full %>%
select(Genotype, AX.115442369, AX.635441221) %>%
distinct()
# 3) assemble total GEBV = intercept + b1·SNP1 + b2·SNP2 + BLUP
gebv_df <- snp_dosage %>%
left_join(blups, by = "Genotype") %>%
mutate(
GEBV_fixed  = AX.115442369 * b1 + AX.635441221 * b2,
GEBV_random = u,
GEBV_total  = GEBV_fixed + GEBV_random
)
head(gebv_df)
fe
# extract the fixed‐effect estimates
fe <- as.data.frame(coef(MYB_model_dom)$fixed)
fe
b0 <- fe[1,]
b1 <- fe[2,]
b2 <- fe[3,]
b3 <- fe[4,]
b4 <- fe[5,]
b5 <- fe[6,]
b6 <- fe[7,]
b7 <- fe[8,]
# 1) get your random‐effect BLUPs
blups <- predict.asreml(MYB_model_dom, classify = "Genotype", aliased  = TRUE)$pvals %>% select(Genotype, u = predicted.value)
# 2) grab each genotype’s SNP dosages
snp_dosage <- df_full %>%
select(Genotype, c(8:14)) %>%
distinct()
View(snp_dosage)
colnames(snp_dosage)
# 3) assemble total GEBV = intercept + b1·SNP1 + b2·SNP2 + BLUP
gebv_df <- snp_dosage %>%
left_join(blups, by = "Genotype") %>%
mutate(
GEBV_fixed  = b0 + AX.115343781 * b1 + AX.115333927 * b2 + AX.115308966 * b3 + AX.115442369 * b4 + AX.635441221 * b5 + AX.115186872 * b6 + AX.115356965 * b7,
GEBV_random = u,
GEBV_total  = GEBV_fixed + GEBV_random
)
head(gebv_df)
comparison <- inner_join(gebv_df[,-c(9)], df_full[,c(4:5)], by = "Genotype")
comparison <- comparison[!is.na(comparison$Genotype),]
View(comparison)
# assuming you’ve read comparison_fixedGEBVs.csv into `df`
cor.test(df$GEBV_total, df$Anthocyans.ug.mg)
# assuming you’ve read comparison_fixedGEBVs.csv into `comparison`
cor.test(comparison$GEBV_total, comparison$Anthocyans.ug.mg)
# bias and RMSE
mean(comparison$GEBV_total - comparison$Anthocyans.ug.mg)   # bias ≃ +1.7
sqrt(mean((comparison$GEBV_total - comparison$Anthocyans.ug.mg)^2))  # RMSE ≃ 1.9
str(comparison)
# bias and RMSE
bias <- mean(comparison$GEBV_total - comparison$Anthocyans.ug.mg,
na.rm = TRUE)
rmse <- sqrt(mean((comparison$GEBV_total - comparison$Anthocyans.ug.mg)^2,
na.rm = TRUE))
bias
rmse
##########     Too few individuals --> does not converge   ############
# ######################### RANDOM Cross-Validation GBLUP #########################
# … [your CV loop, metrics calculation, etc.] …
# Set seed and number of iterations
set.seed(42)
n_repeats <- 10
# Store overall metrics for each iteration
cv_metrics <- data.frame(
R2_overall       = numeric(n_repeats),
RMSE_overall     = numeric(n_repeats),
Pearson_r_overall = numeric(n_repeats)
)
# Run repeated CV
# Define number of folds and compute test size
n_folds <- 5
n_total <- length(unique(df_full$Genotype))
n_test_per_fold <- ceiling(n_total / n_folds)  # Round up
cat("5-fold CV: Using", n_test_per_fold, "genotypes as test set per fold.\n")
for (i in 1:n_repeats) {
Test_1 <- sample(names, n_test_per_fold)
cv_df <- df_full
cv_df$Anthocyans.ug.mg[cv_df$Genotype %in% Test_1] <- NA
MYB_model_dom <- asreml(fixed = fmla,
random   = ~ vm(Genotype, Ginv_noMYB) + vm(Genotype, Dinv_noMYB)+ at(Location):Row + at(Location):Column,
residual = ~ units,
data     = df_full,
na.action = na.method(y = "include", x = "include"))
MYB_model_dom <- update.asreml(MYB_model_dom, maxit = 30)
# Predict GEBVs
pred_cv <- predict.asreml(MYB_model_dom, classify = "Genotype", aliased = TRUE)$pvals
colnames(pred_cv)[colnames(pred_cv) == "predicted.value"] <- "GEBV"
pred_cv$Observed <- df_full$Anthocyans.ug.mg[match(pred_cv$Genotype, df_full$Genotype)]
pred_cv$pop <- df_full$pop[match(pred_cv$Genotype, df_full$Genotype)]
# Keep only test individuals
pred_cv <- pred_cv[!is.na(pred_cv$Observed) & pred_cv$Genotype %in% Test_1, ]
# Save metrics
cv_metrics$R2_overall[i]        <- rsq_vec(pred_cv$Observed, pred_cv$GEBV)
cv_metrics$RMSE_overall[i]      <- rmse_vec(pred_cv$Observed, pred_cv$GEBV)
cv_metrics$Pearson_r_overall[i] <- cor(pred_cv$Observed, pred_cv$GEBV)
# Save predictions (for plotting later)
if (i == 1) {
cv1_df <- pred_cv
} else {
cv1_df <- rbind(cv1_df, pred_cv)
}
}
